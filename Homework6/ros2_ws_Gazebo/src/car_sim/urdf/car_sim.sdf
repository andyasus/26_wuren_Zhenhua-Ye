<sdf version='1.11'>
  <model name='shixi_car'>
    <!-- ============================================ -->
    <!-- base_link (车身主体)                          -->
    <!-- ============================================ -->
    <link name='base_link'>
      <inertial>
        <pose>0.0029268292682926851 0 0.0021463414634146361 0 0 0</pose>
        <mass>2.0499999999999989</mass>
        <inertia>
          <ixx>0.0077635560975609762</ixx>
          <ixy>0</ixy>
          <ixz>-0.00070712195121951224</ixz>
          <iyy>0.033245995121951213</iyy>
          <iyz>0</iyz>
          <izz>0.038817439024390242</izz>
        </inertia>
      </inertial>
      <collision name='base_link_collision'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.43 0.2 0.06</size>
          </box>
        </geometry>
      </collision>
      <visual name='base_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.43 0.2 0.06</size>
          </box>
        </geometry>
        <material>
          <diffuse>0 0.5 1 1</diffuse>
          <ambient>0 0.5 1 1</ambient>
        </material>
      </visual>
    </link>

    <!-- ============================================ -->
    <!-- 传感器独立 Links (不再被 lump 进 base_link)    -->
    <!-- ============================================ -->

    <!-- camera_link -->
    <link name='camera_link'>
      <pose relative_to='camera_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <visual name='camera_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.050000000000000003 0.050000000000000003 0.029999999999999999</size>
          </box>
        </geometry>
        <material>
          <diffuse>1 1 1 1</diffuse>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <sensor name='camera' type='camera'>
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <pose>0 0 0 0 0 0</pose>
        <camera>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <distortion>
            <k1>0</k1>
            <k2>0</k2>
            <k3>0</k3>
            <p1>0</p1>
            <p2>0</p2>
            <center>0.5 0.5</center>
          </distortion>
          <horizontal_fov>1.0469999999999999</horizontal_fov>
          <clip>
            <near>0.10000000000000001</near>
            <far>100</far>
          </clip>
        </camera>
      </sensor>
    </link>

    <!-- lidar_link -->
    <link name='lidar_link'>
      <pose relative_to='lidar_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <visual name='lidar_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.029999999999999999</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>1 1 1 1</diffuse>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <sensor name='lidar' type='lidar'>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <pose>0 0 0 0 0 0</pose>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.1415899999999999</min_angle>
              <max_angle>3.1415899999999999</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
              <resolution>0.10000000000000001</resolution>
              <min_angle>-0.52359880000000003</min_angle>
              <max_angle>0.52359880000000003</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.10000000000000001</min>
            <max>10</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
      </sensor>
    </link>

    <!-- gps_link -->
    <link name='gps_link'>
      <pose relative_to='gps_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <visual name='gps_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.040000000000000001 0.02 0.0050000000000000001</size>
          </box>
        </geometry>
        <material>
          <diffuse>1 1 1 1</diffuse>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <sensor name='gps' type='navsat'>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <pose>0 0 0 0 0 0</pose>
        <navsat/>
      </sensor>
    </link>

    <!-- imu_link -->
    <link name='imu_link'>
      <pose relative_to='imu_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <visual name='imu_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.029999999999999999 0.029999999999999999 0.01</size>
          </box>
        </geometry>
        <material>
          <diffuse>1 1 1 1</diffuse>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <sensor name='imu' type='imu'>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <pose>0 0 0 0 0 0</pose>
        <imu>
          <angular_velocity>
            <x>
              <noise type='none'/>
            </x>
            <y>
              <noise type='none'/>
            </y>
            <z>
              <noise type='none'/>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type='none'/>
            </x>
            <y>
              <noise type='none'/>
            </y>
            <z>
              <noise type='none'/>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <!-- magnetometer_link -->
    <link name='magnetometer_link'>
      <pose relative_to='magnetometer_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <visual name='magnetometer_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.02 0.02 0.01</size>
          </box>
        </geometry>
        <material>
          <diffuse>1 1 1 1</diffuse>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <sensor name='magnetometer' type='magnetometer'>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <pose>0 0 0 0 0 0</pose>
        <magnetometer/>
      </sensor>
    </link>

    <!-- ============================================ -->
    <!-- 传感器固定关节 (连接各传感器 link 到 base_link) -->
    <!-- ============================================ -->
    <joint name='camera_joint' type='fixed'>
      <pose relative_to='base_link'>0.20000000000000001 0 0.10000000000000001 0 0 0</pose>
      <parent>base_link</parent>
      <child>camera_link</child>
    </joint>

    <joint name='lidar_joint' type='fixed'>
      <pose relative_to='base_link'>0.29999999999999999 0 0.14999999999999999 0 0 0</pose>
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

    <joint name='gps_joint' type='fixed'>
      <pose relative_to='base_link'>0 0 0.050000000000000003 0 0 0</pose>
      <parent>base_link</parent>
      <child>gps_link</child>
    </joint>

    <joint name='imu_joint' type='fixed'>
      <pose relative_to='base_link'>0.050000000000000003 0 0.02 0 0 0</pose>
      <parent>base_link</parent>
      <child>imu_link</child>
    </joint>

    <joint name='magnetometer_joint' type='fixed'>
      <pose relative_to='base_link'>-0.05 0 0.12 0 0 0</pose>
      <parent>base_link</parent>
      <child>magnetometer_link</child>
    </joint>

    <!-- ============================================ -->
    <!-- 车轮 joints 和 links                         -->
    <!-- ============================================ -->
    <joint name='fl_wheel_joint' type='revolute'>
      <pose relative_to='base_link'>0.14999999999999999 0.074999999999999997 -0.02 0 0 0</pose>
      <parent>base_link</parent>
      <child>fl_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
        <dynamics>
          <damping>0.050000000000000003</damping>
          <friction>0.10000000000000001</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='fl_wheel_link'>
      <pose relative_to='fl_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.14999999999999999</mass>
        <inertia>
          <ixx>0.00012</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>6.7999999999999999e-05</iyy>
          <iyz>0</iyz>
          <izz>6.7999999999999999e-05</izz>
        </inertia>
      </inertial>
      <collision name='fl_wheel_link_collision'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.025000000000000001</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='fl_wheel_link_visual'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.025000000000000001</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='fr_wheel_joint' type='revolute'>
      <pose relative_to='base_link'>0.14999999999999999 -0.074999999999999997 -0.02 0 0 0</pose>
      <parent>base_link</parent>
      <child>fr_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
        <dynamics>
          <damping>0.050000000000000003</damping>
          <friction>0.10000000000000001</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='fr_wheel_link'>
      <pose relative_to='fr_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.14999999999999999</mass>
        <inertia>
          <ixx>0.00012</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>6.7999999999999999e-05</iyy>
          <iyz>0</iyz>
          <izz>6.7999999999999999e-05</izz>
        </inertia>
      </inertial>
      <collision name='fr_wheel_link_collision'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.025000000000000001</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='fr_wheel_link_visual'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.025000000000000001</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='rl_wheel_joint' type='revolute'>
      <pose relative_to='base_link'>-0.14999999999999999 0.074999999999999997 -0.02 0 0 0</pose>
      <parent>base_link</parent>
      <child>rl_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
        <dynamics>
          <damping>0.050000000000000003</damping>
          <friction>0.10000000000000001</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='rl_wheel_link'>
      <pose relative_to='rl_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.14999999999999999</mass>
        <inertia>
          <ixx>0.00012</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>6.7999999999999999e-05</iyy>
          <iyz>0</iyz>
          <izz>6.7999999999999999e-05</izz>
        </inertia>
      </inertial>
      <collision name='rl_wheel_link_collision'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.025000000000000001</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='rl_wheel_link_visual'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.025000000000000001</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='rr_wheel_joint' type='revolute'>
      <pose relative_to='base_link'>-0.14999999999999999 -0.074999999999999997 -0.02 0 0 0</pose>
      <parent>base_link</parent>
      <child>rr_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
        <dynamics>
          <damping>0.050000000000000003</damping>
          <friction>0.10000000000000001</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='rr_wheel_link'>
      <pose relative_to='rr_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.14999999999999999</mass>
        <inertia>
          <ixx>0.00012</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>6.7999999999999999e-05</iyy>
          <iyz>0</iyz>
          <izz>6.7999999999999999e-05</izz>
        </inertia>
      </inertial>
      <collision name='rr_wheel_link_collision'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.025000000000000001</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='rr_wheel_link_visual'>
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.025000000000000001</length>
            <radius>0.040000000000000001</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <!-- ============================================ -->
    <!-- 模型初始位姿                                  -->
    <!-- ============================================ -->
    <pose>0 -15 0.059999999999999998 0 0 1.5708</pose>

    <!-- ============================================ -->
    <!-- AckermannSteering 插件                       -->
    <!-- ============================================ -->
    <plugin name='gz::sim::systems::AckermannSteering' filename='gz-sim-ackermann-steering-system'>
      <topic>/cmd_vel</topic>
      <wheel_base>0.3</wheel_base>
      <wheel_track>0.15</wheel_track>
      <max_steering_angle>0.7</max_steering_angle>
      <wheel_radius>0.04</wheel_radius>
      <rear_left_joint>rl_wheel_joint</rear_left_joint>
      <rear_right_joint>rr_wheel_joint</rear_right_joint>
      <front_left_joint>fl_wheel_joint</front_left_joint>
      <front_right_joint>fr_wheel_joint</front_right_joint>
      <odom_topic>/odometry</odom_topic>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <update_rate>30.0</update_rate>
      <max_wheel_torque>20.0</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
    </plugin>

    <!-- 传感器系统插件（必须在模型级加载，不能在世界级加载） -->
    <plugin filename='gz-sim-sensors-system' name='gz::sim::systems::Sensors'>
      <render_engine>ogre</render_engine>
    </plugin>
    <plugin filename='gz-sim-imu-system' name='gz::sim::systems::Imu'/>
    <plugin filename='gz-sim-navsat-system' name='gz::sim::systems::NavSat'/>
    <plugin filename='gz-sim-magnetometer-system' name='gz::sim::systems::Magnetometer'/>

  </model>
</sdf>
